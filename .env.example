# LLM Provider (choose one)
LLM_PROVIDER=mistral          # mistral, openai, ollama, or openrouter

# API keys (required for cloud providers)
MISTRAL_API_KEY=xxx           # https://console.mistral.ai
# OPENAI_API_KEY=sk-...       # https://platform.openai.com
# OPENROUTER_API_KEY=sk-...   # https://openrouter.ai

# Ollama (for local inference, no API key needed)
# OLLAMA_HOST=http://localhost:11434
# LLM_PROVIDER=ollama

# Optional: NCBI Entrez email (for higher rate limits)
NCBI_EMAIL=your@email.com

# Optional: LangSmith tracing
# LANGCHAIN_API_KEY=lsv2_...
# LANGCHAIN_TRACING_V2=true
